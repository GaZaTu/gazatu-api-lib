{
  "tasks": {
    "cache": "DENO_DIR=.deno-cache deno cache src/index.ts",
    "test": "DENO_DIR=.deno-cache deno run --allow-all --unstable-ffi --unstable-raw-imports test/main.ts"
  },
  "imports": {
    "hono": "npm:hono@4.11.3",
    "graphql": "npm:graphql@^16.8.1",
    "~/bundled/": "./test/bundled/"
  },
  "compilerOptions": {
    "strict": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-empty-pattern",
        "no-explicit-any",
        "no-unused-vars"
      ]
    }
  },
  "fmt": {
    "semiColons": false,
    "singleQuote": false,
    "indentWidth": 2,
    "useTabs": false,
    "lineWidth": 160,
    "include": [
      "src/"
    ]
  },
  "lock": false
}
